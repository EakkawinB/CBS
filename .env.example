# CBS Bot — โหมดส่วนตัว
# รัน setup ครั้งแรก: python setup.py
# รันทุกครั้ง:      .\run.ps1

# === จำเป็น (จาก LINE Developers) ===
CHANNEL_ACCESS_TOKEN=
CHANNEL_SECRET=

# === ใส่หลังพิมพ์ "id" ใน LINE ครั้งแรก ===
MY_LINE_USER_ID=

# === ตั้งค่าส่วนตัว ===
DEFAULT_CITY=กรุงเทพ
ENABLE_MONITOR=true
PORT=5000

# === ไม่บังคับ ===
OPENWEATHER_API_KEY=

# ENCRYPTION_KEY สร้างอัตโนมัติที่ data/.local_key — ไม่ต้องใส่เอง
